require "shellwords"

default_platform(:ios)

REPO_ROOT = File.expand_path("../..", __dir__)
ENV["PATH"] = "#{Gem.bindir}:#{ENV.fetch("PATH")}"

def required_env(name)
  value = ENV[name]
  UI.user_error!("Missing required environment variable: #{name}") if value.to_s.strip.empty?
  value
end

def normalized_private_key(value)
  key = value.to_s.strip
  key = key.gsub("\\n", "\n")
  unless key.include?("BEGIN PRIVATE KEY") && key.include?("END PRIVATE KEY")
    UI.user_error!("ASC_KEY_P8 must contain the full App Store Connect .p8 private key")
  end
  key
end

def pubspec_version_name
  pubspec = File.read(File.expand_path("../../pubspec.yaml", __dir__))
  version_line = pubspec.lines.find { |line| line.start_with?("version:") }
  UI.user_error!("pubspec.yaml is missing a version line") unless version_line

  version_line.split(":", 2).last.strip.split("+", 2).first
end

def write_app_store_key_file(key_id, key_content)
  path = File.expand_path("AuthKey_#{key_id}.p8", __dir__)
  File.write(path, key_content)
  File.chmod(0o600, path)
  path
end

def app_store_connect_token(key_id, issuer_id, key_content)
  require "jwt"
  require "openssl"

  JWT.encode(
    {
      iss: issuer_id,
      exp: Time.now.to_i + 600,
      aud: "appstoreconnect-v1"
    },
    OpenSSL::PKey::EC.new(key_content),
    "ES256",
    {
      kid: key_id,
      typ: "JWT"
    }
  )
end

def app_store_connect_request(method, path, token)
  require "json"
  require "net/http"
  require "uri"

  uri = path.start_with?("http") ? URI(path) : URI("https://api.appstoreconnect.apple.com#{path}")
  request = method == :delete ? Net::HTTP::Delete.new(uri) : Net::HTTP::Get.new(uri)
  request["Authorization"] = "Bearer #{token}"

  response = Net::HTTP.start(uri.host, uri.port, use_ssl: true) do |http|
    http.request(request)
  end

  unless response.is_a?(Net::HTTPSuccess) || response.is_a?(Net::HTTPNoContent)
    UI.user_error!("App Store Connect #{method.to_s.upcase} #{uri.path} failed: HTTP #{response.code}")
  end

  response.body.to_s.empty? ? {} : JSON.parse(response.body)
end

def ios_development_certificates(token)
  require "uri"

  query = URI.encode_www_form(
    "filter[certificateType]" => "IOS_DEVELOPMENT",
    "fields[certificates]" => "name,certificateType,displayName,serialNumber,platform,expirationDate",
    "limit" => "200"
  )
  path = "/v1/certificates?#{query}"
  certificates = []

  loop do
    body = app_store_connect_request(:get, path, token)
    certificates.concat(body.fetch("data", []))
    path = body.dig("links", "next")
    break unless path
  end

  certificates
end

def prune_stale_api_created_development_certificate(key_id, issuer_id, key_content)
  require "time"

  token = app_store_connect_token(key_id, issuer_id, key_content)
  certificates = ios_development_certificates(token)
  candidates = certificates.select do |certificate|
    attributes = certificate.fetch("attributes", {})
    [attributes["displayName"], attributes["name"]].compact.any? do |label|
      label.include?("Created via API")
    end
  end

  UI.message(
    "Found #{certificates.length} iOS development certificates; " \
    "#{candidates.length} are API-created cleanup candidates"
  )
  return if candidates.empty? || certificates.length < 2

  certificate = candidates.min_by do |candidate|
    Time.parse(candidate.dig("attributes", "expirationDate").to_s)
  rescue ArgumentError, TypeError
    Time.at(0)
  end

  label = certificate.dig("attributes", "displayName") ||
          certificate.dig("attributes", "name") ||
          "unnamed certificate"
  UI.important(
    "Revoking stale API-created iOS development certificate #{certificate.fetch("id")} " \
    "(#{label}) to keep CI automatic signing below Apple's certificate limit"
  )
  app_store_connect_request(:delete, "/v1/certificates/#{certificate.fetch("id")}", token)
end

platform :ios do
  desc "Build the Flutter iOS app and upload it to TestFlight"
  lane :beta do
    app_identifier = ENV.fetch("IOS_BUNDLE_ID", "com.poiseai.app")
    team_id = required_env("APPLE_TEAM_ID")
    key_id = required_env("ASC_KEY_ID")
    issuer_id = required_env("ASC_ISSUER_ID")
    key_content = normalized_private_key(required_env("ASC_KEY_P8"))
    build_name = ENV.fetch("FLUTTER_BUILD_NAME", pubspec_version_name)
    build_number = ENV.fetch("FLUTTER_BUILD_NUMBER", Time.now.utc.strftime("%Y%m%d%H%M"))
    api_base_url = ENV.fetch("POISE_API_BASE_URL", "https://poiseai.brainpad.me/api/v1")
    ws_url = ENV.fetch("POISE_WS_URL", "wss://poiseai.brainpad.me/api/v1/ws")
    changelog = ENV.fetch("TESTFLIGHT_CHANGELOG", "Poise CI build #{build_number}")
    apple_id = ENV["APP_STORE_APP_ID"]
    key_path = write_app_store_key_file(key_id, key_content)

    api_key = app_store_connect_api_key(
      key_id: key_id,
      issuer_id: issuer_id,
      key_content: key_content,
      duration: 1200,
      in_house: false
    )
    prune_stale_api_created_development_certificate(key_id, issuer_id, key_content)

    update_code_signing_settings(
      path: "Runner.xcodeproj",
      use_automatic_signing: true,
      team_id: team_id,
      targets: ["Runner"]
    )

    sh("cd #{Shellwords.escape(REPO_ROOT)} && flutter pub get")
    sh("cd #{Shellwords.escape(REPO_ROOT)} && flutter analyze")
    sh("cd #{Shellwords.escape(REPO_ROOT)} && flutter test")
    sh("cd #{Shellwords.escape(File.join(REPO_ROOT, "ios"))} && bundle exec pod install")
    sh([
      "cd #{Shellwords.escape(REPO_ROOT)} && flutter build ios --release --no-codesign",
      "--build-name=#{Shellwords.escape(build_name)}",
      "--build-number=#{Shellwords.escape(build_number)}",
      "--dart-define=POISE_API_BASE_URL=#{Shellwords.escape(api_base_url)}",
      "--dart-define=POISE_WS_URL=#{Shellwords.escape(ws_url)}"
    ].join(" "))

    signing_xcargs = [
      "-allowProvisioningUpdates",
      "-authenticationKeyPath #{Shellwords.escape(key_path)}",
      "-authenticationKeyID #{Shellwords.escape(key_id)}",
      "-authenticationKeyIssuerID #{Shellwords.escape(issuer_id)}",
      "DEVELOPMENT_TEAM=#{Shellwords.escape(team_id)}"
    ].join(" ")

    ipa_path = build_app(
      workspace: "Runner.xcworkspace",
      scheme: "Runner",
      configuration: "Release",
      clean: true,
      output_directory: "../build/ios/ipa",
      output_name: "Poise.ipa",
      export_method: "app-store",
      export_options: {
        method: "app-store",
        signingStyle: "automatic",
        teamID: team_id,
        manageAppVersionAndBuildNumber: false
      },
      xcargs: signing_xcargs
    )

    upload_to_testflight(
      api_key: api_key,
      app_identifier: app_identifier,
      apple_id: apple_id,
      ipa: ipa_path,
      changelog: changelog,
      distribute_external: false,
      skip_waiting_for_build_processing: true
    )
  ensure
    File.delete(key_path) if defined?(key_path) && key_path && File.exist?(key_path)
  end
end
